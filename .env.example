# Fortuna environment — copy to .env.local and fill in (Phase 5). .env.local is
# gitignored. Restart the dev server after editing.

# Phase 5a — Neon Postgres pooled connection string (the one with -pooler).
DATABASE_URL=

# Phase 5b — Auth.js. Generate AUTH_SECRET with:  npx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
